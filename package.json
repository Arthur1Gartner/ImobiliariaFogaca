{
  "name": "alceu-fogaca-imoveis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:site",
    "dev:site": "vite --config vite.site.config.mjs --configLoader native",
    "dev:dashboard": "vite --config vite.dashboard.config.mjs --configLoader native",
    "build": "npm run build:shared && npm run build:site && npm run build:dashboard",
    "build:shared": "tsc -p packages/shared",
    "build:site": "vite build --config vite.site.config.mjs --configLoader native",
    "build:dashboard": "vite build --config vite.dashboard.config.mjs --configLoader native",
    "build:dashboard:vercel": "vite build --config vite.dashboard.config.mjs --configLoader native --base=/dashboard/",
    "build:vercel": "npm run build:shared && npm run build:site && npm run build:dashboard:vercel && node scripts/prepare-vercel-output.mjs",
    "typecheck": "tsc -p packages/shared && tsc -p apps/site --noEmit && tsc -p apps/dashboard --noEmit",
    "import:site": "node scripts/import-existing-site.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.75.0",
    "@vercel/speed-insights": "^1.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
